# Copy to .env and adjust. Used by docker compose and local dev.

# API auth (set a long random string in production)
API_TOKEN=change-me-to-a-long-random-secret

# SQLite (default) or postgresql://user:pass@db:5432/tdlweb
DATABASE_URL=sqlite:////data/app.db

# Redis for Celery
REDIS_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Data layout inside container (must match volume mount)
DATA_HOME=/data
TDL_HOME=/data/.tdl
DOWNLOAD_DIR=/data/downloads

# CORS (comma-separated origins, or * for any)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Celery task limits (seconds)
CELERY_TASK_SOFT_TIME_LIMIT=82800
CELERY_TASK_TIME_LIMIT=86400

# tdl release used in Dockerfile (build-arg)
# TDL_VERSION=v0.20.2
